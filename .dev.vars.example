# Local development secrets for the Cloudflare Workers runtime.
# Copy to `.dev.vars` (which is gitignored) and fill in real values.
#
# In production these are set with Wrangler, not committed:
#   wrangler secret put SESSION_SECRET

# Which Next.js env file set to load locally (OpenNext). Usually "development".
NEXTJS_ENV=development

# Admin passwords are now per-Company, hashed in D1 (ADR-0004); there is no
# global ADMIN_PASSWORD secret anymore.

# Secret key for signing the admin session cookie (HMAC-SHA256).
# Use a long random string, e.g. `openssl rand -base64 32`.
SESSION_SECRET=change-me-to-a-long-random-string
